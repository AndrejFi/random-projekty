    param_hdrs = ["Parameter", "Used Value", "Source / Rationale", "Reasonable Range", "Sensitivity"]
    for j, h in enumerate(param_hdrs, 1):
        ws.cell(row=row, column=j, value=h)
    sh(ws, row, 5); row += 1

    wacc_src = (f"Full WACC: E/(D+E)×Re + D/(D+E)×Rd×(1-t)"
                if dcf["wacc_method"] == "full_wacc"
                else f"CAPM only (no debt data): Rf + β×ERP")

    beta_src = f"yfinance (clamped 0.3-3.0): {dcf['beta']:.2f}"

    params = [
        ("WACC", dcf["wacc"], PCT, wacc_src, "6% - 14%", "High", 0.06, 0.14),
        ("Cost of Equity (Re)", dcf["re"], PCT,
         f"CAPM: {dcf['rf']:.1%} + {dcf['beta']:.2f} × {dcf['erp']:.1%}", "7% - 18%", "Medium", 0.07, 0.18),
        ("Cost of Debt (Rd)", dcf["rd"] if dcf["rd"] else "N/A",
         PCT if dcf["rd"] else None,
         "Interest Exp / Total Debt" if dcf["rd"] else "Not available",
         "2% - 10%", "Medium", 0.02, 0.10),
        ("Terminal Growth", dcf["terminal_g"], PCT,
         f"Sector-calibrated ({info.get('sector', '?')})", "1.5% - 3.5%", "Very High", 0.015, 0.035),
        ("FCF Growth (Y1-5)", dcf["fcf_growth_1"], PCT,
         f"Hist. CAGR ({len(fcf_hist)}yr), cap {sbm['growth_cap']:.0%}",
         f"{sbm['growth_floor']:.0%} - {sbm['growth_cap']:.0%}", "Medium",
         sbm["growth_floor"], sbm["growth_cap"]),
        ("FCF Growth (Y6-10)", dcf["fcf_growth_2"], PCT,
