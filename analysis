        sc_cell.alignment = Alignment(horizontal="center"); sc_cell.fill = sens_fill

        alt_row(ws, row, 5)
        row += 1

    # ════════════════════════════════════════════════
    # SECTION B3: SENSITIVITY ANALYSIS
    # ════════════════════════════════════════════════
    row += 1
    row = _write_sensitivity_table(ws, row, dcf, stock, info)

    # ════════════════════════════════════════════════
    # SECTION B4: SANITY CHECKS
    # ════════════════════════════════════════════════
    ws.merge_cells(f"A{row}:G{row}")
    ws[f"A{row}"].value = "SANITY CHECKS"; ws[f"A{row}"].font = S_FONT; row += 2

    chk_hdrs = ["Check", "Value", "Status", "Comment"]
    for j, h in enumerate(chk_hdrs, 1):
        ws.cell(row=row, column=j, value=h)
    sh(ws, row, 4); row += 1

    checks = []

    # 1. Terminal Value Dominance
    total_val = dcf["pv_tv"] + dcf["pv_fcfs"]
    tv_pct = dcf["pv_tv"] / total_val if total_val > 0 else 0
    tv_ok = tv_pct < 0.75
    checks.append(("Terminal Value Dominance", tv_pct, PCT, tv_ok,
                    "OK — balanced" if tv_ok else "⚠ Model heavily relies on terminal assumptions"))

    # 2. Reverse DCF — implied growth (perpetuity approximation)
    mkt_val = cp * dcf["shr"] if cp and dcf["shr"] else 0
    implied_g = wacc - (lfcf / mkt_val) if mkt_val > 0 and lfcf else None
    ig_ok = implied_g is not None and -0.05 < implied_g < 0.08
    checks.append(("Implied Growth (Reverse DCF, perpetuity approx.)", implied_g, PCT, ig_ok,
                    "OK — market expectation reasonable" if ig_ok else
                    ("Market implies very optimistic growth" if implied_g and implied_g >= 0.08
                     else "Cannot compute" if implied_g is None
                     else "Market implies negative growth")))

    # 3. WACC vs ROIC
    tax_r = dcf["tax_rate"]
    nopat = oi * (1 - tax_r) if oi else None
    invested_cap = (ta - clb) if ta and clb else None
    roic = nopat / invested_cap if nopat and invested_cap and invested_cap > 0 else None
    roic_ok = roic is not None and roic > wacc
    checks.append(("WACC vs ROIC", roic, PCT, roic_ok,
                    "Firm creates value above cost of capital" if roic_ok else
                    ("ROIC below WACC — destroying value" if roic is not None else "Cannot compute")))

    # 4. FCF Projection Sanity
    y5_fcf = dcf["projected_fcfs"][4] if len(dcf["projected_fcfs"]) >= 5 else 0
    proj_ok = True
    if lfcf and lfcf > 0:
        proj_ok = y5_fcf < 2.5 * lfcf
    checks.append(("FCF Y5 Projection Sanity", y5_fcf, CURM, proj_ok,
                    "OK — within historical trend" if proj_ok else "⚠ Aggressive projection"))

    # 5. Debt Sustainability
    debt_payback = net_debt / lfcf if lfcf and lfcf > 0 and net_debt > 0 else None
    dp_ok = debt_payback is not None and debt_payback < 5
    checks.append(("Debt Sustainability (Net Debt / FCF)", debt_payback, DEC, dp_ok,
                    f"Payback in {debt_payback:.1f} years" if debt_payback and dp_ok else
                    ("High debt — payback > 5 years" if debt_payback else
                     "N/A (net cash or no FCF)")))

    # 6. FCF Data Quality
    fcf_ok = dcf["fcf_source"] == "direct"
    src_labels = {"direct": "Direct from financials", "ocf_capex": "OCF − CapEx",
                  "estimated_ni": "⚠ Estimated from Net Income (70%)", "no_data": "⚠ No data available"}
    checks.append(("FCF Data Source", src_labels.get(dcf["fcf_source"], "?"), None, fcf_ok,
                    "OK — reliable source" if fcf_ok else "Lower reliability — verify manually"))

    for cname, cval, cfmt_chk, c_ok, ccomment in checks:
        ws.cell(row=row, column=1, value=cname).font = L_FONT
        ws.cell(row=row, column=1).border = BDR
        c = ws.cell(row=row, column=2, value=cval)
        if cfmt_chk and cval is not None:
            sd(c, cfmt_chk)
        else:
            c.font = D_FONT; c.border = BDR; c.alignment = Alignment(horizontal="center")

        status_cell = ws.cell(row=row, column=3)
        if c_ok:
            status_cell.value = "✅ OK"; status_cell.font = OK_FONT
        else:
            status_cell.value = "⚠️ Warning"; status_cell.font = WARN_FONT
        status_cell.border = BDR; status_cell.alignment = Alignment(horizontal="center")

        ws.merge_cells(f"D{row}:G{row}")
        cmt = ws.cell(row=row, column=4, value=ccomment)
        cmt.font = NOTE_FONT; cmt.border = BDR
        cmt.alignment = Alignment(horizontal="left", wrap_text=True)

        alt_row(ws, row, 7)
        row += 1

    # ════════════════════════════════════════════════
    # SECTION C: QUALITATIVE ANALYSIS
    # ════════════════════════════════════════════════
    row += 1
    ws.merge_cells(f"A{row}:G{row}")
    ws[f"A{row}"].value = "QUALITATIVE ANALYSIS"; ws[f"A{row}"].font = S_FONT; row += 2

    # ── C1: Competitive Moat (FIX 2.3 — multi-factor scoring) ──
    ws.cell(row=row, column=1, value="COMPETITIVE MOAT").font = L_FONT; row += 1

    sector = info.get("sector", "")
    moat_map = {
        "Technology": "Switching Costs / Network Effects",
        "Communication Services": "Network Effects / Brand",
        "Consumer Defensive": "Brand / Intangible Assets",
        "Consumer Cyclical": "Brand / Intangible Assets",
        "Healthcare": "Patents / Intangible Assets",
        "Financial Services": "Switching Costs / Scale",
        "Utilities": "Efficient Scale / Regulation",
        "Industrials": "Cost Advantage / Scale",
        "Energy": "Cost Advantage / Scale",
        "Real Estate": "Efficient Scale",
        "Basic Materials": "Cost Advantage",
    }
    moat_type = moat_map.get(sector, "Undetermined")

    # Multi-factor moat scoring
    moat_score = 0
    gm_wide = sbm.get("gross_margin_wide")
    if gross_margin is not None and gm_wide is not None and gross_margin > gm_wide:
        moat_score += 1
    if roe is not None and roe > sbm.get("roe_good", 0.15):
        moat_score += 1
    if rev_growth is not None and rev_growth > 0.03:
        moat_score += 1
    if de_ratio is not None and de_ratio < (sbm.get("de_threshold") or 2.0):
        moat_score += 1
    if fcf_margin is not None and fcf_margin > 0.10:
        moat_score += 1

    if moat_score >= 4:
        moat_strength = "Wide"
    elif moat_score >= 2:
        moat_strength = "Narrow"
    else:
        moat_strength = "None / Weak"

    # Moat trend
    if gross_margin is not None and gm_prev is not None:
        gm_delta = gross_margin - gm_prev
        if gm_delta > 0.02:
            moat_trend = "Strengthening"
        elif gm_delta < -0.02:
            moat_trend = "Weakening"
        else:
            moat_trend = "Stable"
    else:
        moat_trend = "N/A"

    for lb, v in [("Moat Type (Sector)", moat_type), ("Moat Strength", f"{moat_strength} ({moat_score}/5)"), ("Moat Trend", moat_trend)]:
        ws.cell(row=row, column=1, value=lb).font = L_FONT; ws.cell(row=row, column=1).border = BDR
        c = ws.cell(row=row, column=2, value=v); c.font = D_FONT; c.border = BDR
        c.alignment = Alignment(horizontal="center")
        alt_row(ws, row, 2)
        row += 1

    row += 1
    ws.merge_cells(f"A{row}:G{row}")
    moat_comment = f"Sector: {sector}. "
    if gross_margin:
        moat_comment += f"Gross margin {gross_margin:.0%}"
        if gm_wide:
            moat_comment += f" (sector wide-moat threshold: {gm_wide:.0%}). "
        else:
            moat_comment += ". "
    else:
        moat_comment += "Insufficient data for margin-based moat assessment. "
    moat_comment += f"Moat score {moat_score}/5 (GM, ROE, Rev Growth, Leverage, FCF Margin)."
    c = ws.cell(row=row, column=1, value=moat_comment)
    c.font = Font(name="Arial", italic=True, color="555555", size=9)
    c.alignment = Alignment(wrap_text=True, vertical="top")
    row += 2

    # ── C2: Bull Case (FIX 2.4 — sector-calibrated thresholds) ──
    ws.cell(row=row, column=1, value="BULL CASE").font = Font(name="Arial", bold=True, color="006100", size=11)
    ws.cell(row=row, column=1).fill = GREEN_BG; ws.cell(row=row, column=1).border = BDR; row += 1

    bull_points = []
    rev_bull = sbm.get("rev_growth_bull", 0.10)
    if rev_growth and rev_growth > rev_bull:
        bull_points.append(f"Strong revenue growth ({rev_growth:.1%} YoY, above {rev_bull:.0%} sector threshold)")
    if fcf_margin and fcf_margin > 0.15:
        bull_points.append(f"Healthy FCF generation ({fcf_margin:.1%} FCF margin)")
    roe_good = sbm.get("roe_good", 0.15)
    if roe and roe > roe_good:
        bull_points.append(f"Above-average ROE ({roe:.1%}, sector benchmark {roe_good:.0%})")
    if current_ratio and current_ratio > 2.0:
        bull_points.append(f"Strong liquidity (Current Ratio: {current_ratio:.2f})")
    dy = info.get("dividendYield")
    if dy and isinstance(dy, (int, float)) and dy > 0.02:
        bull_points.append(f"Attractive dividend yield ({dy:.1%})")
    rec = info.get("recommendationKey", "")
    if rec in ("buy", "strong_buy"):
        bull_points.append(f"Analyst consensus: {rec.upper()}")
    if weighted_mos > 0.15:
        bull_points.append(f"Undervalued based on weighted DCF ({weighted_mos:.0%} upside)")
    if gross_margin and gm_wide and gross_margin > gm_wide:
        bull_points.append(f"High gross margin ({gross_margin:.0%}) — above sector wide-moat threshold")

    if not bull_points:
        bull_points.append("No strong bullish signals detected from available data")

    for pt in bull_points[:6]:
        ws.merge_cells(f"A{row}:G{row}")
        c = ws.cell(row=row, column=1, value=f"•  {pt}")
        c.font = Font(name="Arial", color="006100", size=10); c.border = BDR
        c.alignment = Alignment(horizontal="left", wrap_text=True)
        row += 1

    row += 1

    # ── C3: Bear Case ──
    ws.cell(row=row, column=1, value="BEAR CASE").font = Font(name="Arial", bold=True, color="C00000", size=11)
    ws.cell(row=row, column=1).fill = RED_BG; ws.cell(row=row, column=1).border = BDR; row += 1

    bear_points = []
    b = info.get("beta")
    if b and isinstance(b, (int, float)) and b > 1.3:
        bear_points.append(f"Higher volatility than market (Beta: {b:.2f})")
    de_thresh = sbm.get("de_threshold")
    if de_ratio is not None and de_thresh is not None and de_ratio > de_thresh:
        bear_points.append(f"Elevated leverage (D/E: {de_ratio:.2f}, sector threshold: {de_thresh:.1f})")
    elif te is not None and te < 0:
        bear_points.append("Negative equity — aggressive buybacks or accumulated losses")
    if lfcf and lfcf < 0:
        bear_points.append("Negative free cash flow — cash burn risk")
    pe_hi = sbm.get("pe_normal", (12, 25))[1]
    tpe = info.get("trailingPE")
    if tpe and isinstance(tpe, (int, float)) and tpe > pe_hi:
        bear_points.append(f"Expensive valuation (P/E: {tpe:.1f}, sector normal range up to {pe_hi})")
    if rev_growth and rev_growth < 0:
        bear_points.append(f"Declining revenue ({rev_growth:.1%} YoY)")
    pr = info.get("payoutRatio")
    if pr and isinstance(pr, (int, float)) and pr > 0.80:
        bear_points.append(f"Dividend payout ratio unsustainably high ({pr:.0%})")
    spf = info.get("shortPercentOfFloat")
    if spf and isinstance(spf, (int, float)) and spf > 0.05:
        bear_points.append(f"Elevated short interest ({spf:.1%} of float)")
    if weighted_mos < -0.15:
        bear_points.append(f"Overvalued based on weighted DCF ({weighted_mos:.0%})")
    if net_margin and net_margin < 0.05:
        bear_points.append(f"Thin net margin ({net_margin:.1%})")
    if dcf["fcf_source"] == "estimated_ni":
        bear_points.append("FCF data unavailable — valuation uses estimated proxy (70% of NI)")

    if not bear_points:
        bear_points.append("No strong bearish signals detected from available data")

    for pt in bear_points[:6]:
        ws.merge_cells(f"A{row}:G{row}")
        c = ws.cell(row=row, column=1, value=f"•  {pt}")
        c.font = Font(name="Arial", color="C00000", size=10); c.border = BDR
        c.alignment = Alignment(horizontal="left", wrap_text=True)
        row += 1

    row += 1

    # ── C4: Management & Ownership ──
    ws.cell(row=row, column=1, value="MANAGEMENT & OWNERSHIP").font = S_FONT; row += 1

    officers = info.get("companyOfficers", [])
    ceo_name = "N/A"
    if officers and isinstance(officers, list):
        for o in officers:
            title = o.get("title", "").lower()
            if "ceo" in title or "chief executive" in title:
                ceo_name = f"{o.get('name', 'N/A')} - {o.get('title', 'N/A')}"; break
        if ceo_name == "N/A" and officers:
            ceo_name = f"{officers[0].get('name', 'N/A')} - {officers[0].get('title', 'N/A')}"

    ins = info.get("heldPercentInsiders")
    inst = info.get("heldPercentInstitutions")
    gov = info.get("overallRisk")

    mgmt_data = [
        ("CEO", ceo_name, None),
        ("Insider Ownership", ins, PCT),
        ("Institutional Ownership", inst, PCT),
        ("Governance Risk Score", gov, DEC),
    ]
    for lb, v, fm in mgmt_data:
        ws.cell(row=row, column=1, value=lb).font = L_FONT
        ws.cell(row=row, column=1).border = BDR
        if v is not None and v != "N/A":
            c = ws.cell(row=row, column=2, value=v)
            if fm:
                sd(c, fm)
            else:
                c.font = D_FONT; c.border = BDR; c.alignment = Alignment(horizontal="center")
        else:
            c = ws.cell(row=row, column=2, value="N/A")
            c.font = Font(name="Arial", color="999999", size=9, italic=True)
            c.border = BDR; c.alignment = Alignment(horizontal="center")
        alt_row(ws, row, 2)
        row += 1

    # Disclaimer
    row += 1
    ws.merge_cells(f"A{row}:G{row}")
    c = ws.cell(row=row, column=1,
                value="Note: This analysis is for informational purposes only and does not constitute investment advice. "
                      "DCF models are highly sensitive to input assumptions. Verify data against SEC filings, "
                      "earnings calls, and multiple independent sources before making investment decisions.")
    c.font = Font(name="Arial", italic=True, color="999999", size=8)
    c.alignment = Alignment(wrap_text=True, vertical="top")

    # ── Formatting ──
    ws.freeze_panes = "A3"
    ws.column_dimensions["A"].width = 32
    for col in ["B", "C", "D", "E", "F", "G"]:
        ws.column_dimensions[col].width = 18


