def create_technical(wb, ticker, hist, info):
    cfmt = get_currency_formats(info)
    ws = wb.create_sheet("Technical Analysis"); ws.sheet_properties.tabColor = "BF8F00"
    if hist is None or hist.empty:
        ws.cell(row=1, column=1, value="No data").font = S_FONT; return

    row = 1
    ws.merge_cells(f"A{row}:H{row}")
    ws[f"A{row}"].value = f"TECHNICAL ANALYSIS - {ticker.upper()}"
    ws[f"A{row}"].font = T_FONT; row += 2

    cl_s = hist["Close"].copy()
    s50 = cl_s.rolling(50).mean(); s200 = cl_s.rolling(200).mean()
    d = cl_s.diff(); gn = d.clip(lower=0); ls = (-d.clip(upper=0))
    ag = gn.rolling(14).mean(); al = ls.rolling(14).mean()
    rs = ag / al; rsi = 100 - (100 / (1 + rs))
    e12 = cl_s.ewm(span=12, adjust=False).mean()
    e26 = cl_s.ewm(span=26, adjust=False).mean()
    ml = e12 - e26; sl_m = ml.ewm(span=9, adjust=False).mean(); mh = ml - sl_m

    hds = ["Date", "Close", "SMA 50", "SMA 200", "RSI (14)", "MACD", "Signal", "MACD Hist"]
    for j, h in enumerate(hds, 1):
        ws.cell(row=row, column=j, value=h)
    sh(ws, row, len(hds)); row += 1; ds = row

    for i in range(len(hist)):
        dt = hist.index[i]
        ws.cell(row=row, column=1, value=dt.strftime("%Y-%m-%d")).font = D_FONT
        ws.cell(row=row, column=1).border = BDR
        for j, s in enumerate([cl_s, s50, s200, rsi, ml, sl_m, mh], 2):
            v = s.iloc[i]
            c = ws.cell(row=row, column=j, value=float(v) if pd.notna(v) else None); sd(c, DEC)
        alt_row(ws, row, 8)
        row += 1

    de = row - 1
    cr = Reference(ws, min_col=1, min_row=ds, max_row=de)
    ch = LineChart(); ch.title = f"{ticker.upper()} - Price & MAs"; ch.style = 10
    ch.width = 30; ch.height = 15; ch.y_axis.title = f"Price ({cfmt['code']})"
    for ci in [2, 3, 4]:
        ch.add_data(Reference(ws, min_col=ci, min_row=ds - 1, max_row=de), titles_from_data=True)
    ch.set_categories(cr)
    for idx, s in enumerate(ch.series):
        s.graphicalProperties.line.width = 18000 if idx == 0 else 14000
        s.graphicalProperties.line.solidFill = ["2E5090", "E67E22", "C0392B"][idx]
    ws.add_chart(ch, "J3")

    rc = LineChart(); rc.title = "RSI (14)"; rc.style = 10; rc.width = 30; rc.height = 10
    rc.y_axis.scaling.min = 0; rc.y_axis.scaling.max = 100
    rc.add_data(Reference(ws, min_col=5, min_row=ds - 1, max_row=de), titles_from_data=True)
    rc.set_categories(cr); rc.series[0].graphicalProperties.line.solidFill = "8E44AD"
    ws.add_chart(rc, "J20")

    mc = BarChart(); mc.title = "MACD Histogram"; mc.style = 10; mc.width = 30; mc.height = 10
    mc.add_data(Reference(ws, min_col=8, min_row=ds - 1, max_row=de), titles_from_data=True)
    mc.set_categories(cr)
    ws.add_chart(mc, "J35")

    ws.freeze_panes = "B4"; aw(ws, 12, 16); ws.column_dimensions["A"].width = 14


