# DCF COMPUTATION ENGINE (COMPLETE REWRITE — FIX 1.1, 1.2, 1.7, 1.8)
# ═══════════════════════════════════════════════════════════════════════

def _compute_dcf(stock, info, wacc_override=None, g1_override=None,
                 g2_override=None, tg_override=None):
    """
    Compute DCF intrinsic value with proper WACC, beta clamping,
    country risk premium, effective tax rate, and FCF fallbacks.
    """
    cf = stock.cashflow
    lfcf = None
    fcf_history = []
    fcf_source = "direct"

    if cf is not None and not cf.empty:
        # Try FCF row directly
        fr = [r for r in cf.index if "free cash flow" in str(r).lower()]
        if fr:
            for ci in range(min(len(cf.columns), 5)):
                v = cf.loc[fr[0]].iloc[ci]
                if pd.notna(v):
                    fcf_history.append(float(v))
            if fcf_history:
                lfcf = fcf_history[0]

        # Fallback: OCF + CapEx (CapEx is typically negative in yfinance)
        if lfcf is None:
            opr = [r for r in cf.index if "operating" in str(r).lower() and "cash" in str(r).lower()]
            cxr = [r for r in cf.index if "capital expenditure" in str(r).lower()]
            if opr and cxr:
                fcf_source = "ocf_capex"
                for ci in range(min(len(cf.columns), 5)):
                    op = cf.loc[opr[0]].iloc[ci]; cx = cf.loc[cxr[0]].iloc[ci]
                    if pd.notna(op) and pd.notna(cx):
                        fcf_history.append(float(op) + float(cx))
                if fcf_history:
                    lfcf = fcf_history[0]

    # FIX 1.2: Better fallback — estimate from Net Income
    if lfcf is None or lfcf == 0:
        ni_val = _get_financial_val(stock, "financials", ["Net Income"], 0)
        if ni_val and ni_val > 0:
            lfcf = ni_val * 0.70
            fcf_source = "estimated_ni"
        elif lfcf is None:
            lfcf = 0
            fcf_source = "no_data"

    # ═══ WACC COMPUTATION (FIX 1.1 — proper WACC, not just cost of equity) ═══
    country = info.get("country", "United States")
    rf = 0.042  # 10Y US Treasury proxy (2025 vintage)
    erp_base = 0.055  # Damodaran US ERP
    crp = COUNTRY_CRP.get(country, 0.01)
    erp = erp_base + crp

    # FIX 1.7: Beta clamping
    beta = info.get("beta")
    if beta and isinstance(beta, (int, float)) and not pd.isna(beta):
        beta = max(0.3, min(beta, 3.0))  # clamp to reasonable range
    else:
        beta = 1.0  # market average fallback

    re = rf + beta * erp  # Cost of Equity (CAPM)

    # Cost of Debt
    market_cap = info.get("marketCap", 0) or 0
    total_debt = _get_financial_val(stock, "balance_sheet",
                                     ["Total Debt", "Long Term Debt"], 0)
    interest_expense = _get_financial_val(stock, "financials",
                                           ["Interest Expense"], 0)

    tax_rate = _get_tax_rate(stock, info)

    # Full WACC calculation
    if total_debt and total_debt > 0 and market_cap and market_cap > 0:
        # Cost of debt
        if interest_expense and total_debt > 0:
            rd = abs(interest_expense) / total_debt
            rd = max(0.01, min(rd, 0.20))  # clamp 1%-20%
        else:
            rd = rf + 0.02  # 200bps spread over risk-free

        total_capital = market_cap + total_debt
        wacc = (market_cap / total_capital) * re + \
               (total_debt / total_capital) * rd * (1 - tax_rate)
        wacc = max(wacc, 0.04)  # floor at 4%
        wacc_method = "full_wacc"
    else:
        wacc = re  # fallback to cost of equity
        wacc_method = "cost_of_equity_only"
        rd = None

    if wacc_override is not None:
        wacc = wacc_override

    # ═══ FCF GROWTH RATES ═══
    sector = info.get("sector", "")
    sbm = SECTOR_BENCHMARKS.get(sector, DEFAULT_SECTOR)

    fcf_growth_1 = 0.10  # default
    if len(fcf_history) >= 2:
        first_fcf = fcf_history[-1]; last_fcf_hist = fcf_history[0]
        n = len(fcf_history) - 1
        if first_fcf > 0 and last_fcf_hist > 0 and n > 0:
            cagr = (last_fcf_hist / first_fcf) ** (1 / n) - 1
            fcf_growth_1 = max(min(cagr, sbm["growth_cap"]), sbm["growth_floor"])

    if g1_override is not None:
        fcf_growth_1 = g1_override

    fcf_growth_2 = fcf_growth_1 * 0.6 if g2_override is None else g2_override
    terminal_g = sbm["terminal_g"] if tg_override is None else tg_override

    shr = _get_shares(info)
    cp = info.get("currentPrice", 0) or 0

    # ═══ PROJECT FCFs ═══
    projected_fcfs = []
    fcf_val = lfcf
    for yr in range(1, 11):
        g = fcf_growth_1 if yr <= 5 else fcf_growth_2
        fcf_val = fcf_val * (1 + g)
        projected_fcfs.append(fcf_val)

    # ═══ DISCOUNT (mid-year convention) ═══
    # Cash flows arrive throughout the year, not at year-end.
    # Standard IB practice: discount at (yr - 0.5) for FCFs.
    pv_fcfs = sum(f / (1 + wacc) ** (yr - 0.5) for yr, f in enumerate(projected_fcfs, 1))

    # Terminal value — point-in-time at end of year 10, discounted full 10 years
    if wacc > terminal_g and projected_fcfs:
        tv = projected_fcfs[-1] * (1 + terminal_g) / (wacc - terminal_g)
        pv_tv = tv / (1 + wacc) ** 10
    else:
        tv = 0; pv_tv = 0

    enterprise_value = pv_fcfs + pv_tv

    # ═══ NET DEBT BRIDGE ═══
    # FCF (yfinance) = FCFF (Free Cash Flow to Firm) → discounted at WACC → Enterprise Value
    # Equity Value = Enterprise Value - Total Debt + Cash
    cash = _get_financial_val(stock, "balance_sheet",
                               ["Cash And Cash Equivalents", "Cash Cash Equivalents And Short Term Investments",
                                "Cash Financial"], 0) or 0
    net_debt = (total_debt or 0) - cash
    equity_value = enterprise_value - net_debt
    intrinsic = equity_value / shr if shr else 0

    # Handle zero/negative price
    if cp and cp > 0:
        mos = (intrinsic - cp) / cp
    else:
        mos = 0

    return {
        "lfcf": lfcf, "fcf_history": fcf_history, "fcf_source": fcf_source,
        "wacc": wacc, "wacc_method": wacc_method, "rf": rf, "erp": erp,
        "erp_base": erp_base, "crp": crp, "beta": beta, "re": re,
        "rd": rd, "tax_rate": tax_rate,
        "total_debt": total_debt, "market_cap": market_cap,
        "cash": cash, "net_debt": net_debt,
        "fcf_growth_1": fcf_growth_1, "fcf_growth_2": fcf_growth_2,
        "terminal_g": terminal_g, "shr": shr, "cp": cp,
        "projected_fcfs": projected_fcfs,
        "pv_fcfs": pv_fcfs, "pv_tv": pv_tv, "tv": tv,
        "enterprise_value": enterprise_value,
        "equity_value": equity_value,
        "intrinsic": intrinsic, "mos": mos,
        "sector_benchmarks": sbm,
    }


