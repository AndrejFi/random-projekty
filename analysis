def _get_financial_val(stock, df_type, row_names, col_idx=0):
    """
    Extract a value from financials/balance_sheet with multiple row aliases.
    row_names can be a string or list of strings to try in order.
    Returns first successful match or None.
    """
    df = getattr(stock, df_type, None)
    if df is None or df.empty:
        return None
    if isinstance(row_names, str):
        row_names = [row_names]
    for rn in row_names:
        m = [r for r in df.index if rn.lower() in str(r).lower()]
        if m and col_idx < len(df.columns):
            v = df.loc[m[0]].iloc[col_idx]
            if pd.notna(v):
                val = float(v)
                if abs(val) > 1e15:  # sanity check
                    continue
                return val
    return None


def _get_tax_rate(stock, info):
    """Get effective tax rate with fallbacks. (FIX 1.9)"""
    # 1. Try yfinance effective tax rate
    eff = info.get("effectiveTaxRate")
    if eff and isinstance(eff, (int, float)) and 0.01 < eff < 0.55:
        return eff
    # 2. Try computing from financials: Tax Provision / Pretax Income
    pretax = _get_financial_val(stock, "financials", ["Pretax Income", "Income Before Tax"], 0)
    tax_prov = _get_financial_val(stock, "financials", ["Tax Provision", "Income Tax Expense"], 0)
    if pretax and tax_prov and pretax > 0:
        computed = tax_prov / pretax
        if 0.01 < computed < 0.55:
            return computed
    # 3. Country-based statutory rate
    country = info.get("country", "United States")
    return COUNTRY_TAX.get(country, 0.21)


def _get_shares(info):
    """Get diluted shares outstanding with fallback. (FIX 1.10)"""
    # Prefer implied (diluted) shares
    shr = info.get("impliedSharesOutstanding")
    if shr and isinstance(shr, (int, float)) and shr > 0:
        return shr
    shr = info.get("sharesOutstanding")
    if shr and isinstance(shr, (int, float)) and shr > 0:
        return shr
    return 1  # absolute fallback to prevent division by zero


