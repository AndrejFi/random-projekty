# MULTI-SCENARIO DCF (NEW — FIX 3.1)
# ═══════════════════════════════════════════════════════════════════════

def _compute_scenarios(stock, info, base_dcf):
    """Compute Bull / Base / Bear scenarios with probability-weighted fair value."""
    scenarios = {
        "Bull": {"g1_mult": 1.3, "wacc_adj": -0.01, "tg_adj": +0.005, "prob": 0.25},
        "Base": {"g1_mult": 1.0, "wacc_adj": 0.0,   "tg_adj": 0.0,   "prob": 0.50},
        "Bear": {"g1_mult": 0.5, "wacc_adj": +0.02, "tg_adj": -0.005, "prob": 0.25},
    }
    results = {}
    weighted_iv = 0

    for name, adj in scenarios.items():
        g1 = base_dcf["fcf_growth_1"] * adj["g1_mult"]
        g2 = g1 * 0.6
        w = base_dcf["wacc"] + adj["wacc_adj"]
        tg = base_dcf["terminal_g"] + adj["tg_adj"]

        # Ensure wacc > terminal_g
        if w <= tg:
            w = tg + 0.02

        dcf = _compute_dcf(stock, info, wacc_override=w, g1_override=g1,
                           g2_override=g2, tg_override=tg)
        iv = dcf["intrinsic"]
        results[name] = {
            "intrinsic": iv,
            "mos": dcf["mos"],
            "wacc": w, "g1": g1, "tg": tg,
            "prob": adj["prob"],
        }
        weighted_iv += iv * adj["prob"]

    return results, weighted_iv


