    print(f"  • Currency-aware formatting ({currency})")
    print(f"  • Negative equity, zero FCF, extreme beta guards")
    print(f"  • Effective tax rate (from financials or country-based)")
    print(f"\n  Tip: Edit blue cells in Valuation to adjust DCF assumptions.\n")


if __name__ == "__main__":
