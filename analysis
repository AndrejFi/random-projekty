def get_currency_formats(info):
    """Return currency format strings based on the company's reporting currency."""
    currency = info.get("currency", "USD")
    sym = CURRENCY_SYMBOLS.get(currency, currency + " ")
    return {
        "CUR": f'{sym}#,##0.00',
        "CURM": f'{sym}#,##0',
        "CURB": f'{sym}#,##0,,,"B"',
        "symbol": sym,
        "code": currency,
    }


