def create_investment_verdict(wb, stock, info, hist):
    cfmt = get_currency_formats(info)
    CUR = cfmt["CUR"]; CURM = cfmt["CURM"]
    ws = wb.create_sheet("Investment Verdict"); ws.sheet_properties.tabColor = "4A148C"

    # ── Compute all data ──
    dcf = _compute_dcf(stock, info)
    intrinsic = dcf["intrinsic"]; cp = dcf["cp"]; mos = dcf["mos"]
    wacc = dcf["wacc"]; lfcf = dcf["lfcf"]
    sbm = dcf["sector_benchmarks"]

    # Multi-scenario
    scenarios, weighted_iv = _compute_scenarios(stock, info, dcf)

    # Use weighted IV for verdict (more robust than single-scenario)
    if cp and cp > 0:
        weighted_mos = (weighted_iv - cp) / cp
    else:
        weighted_mos = 0

    # Financial data
    rev0 = _get_financial_val(stock, "financials", ["Total Revenue"], 0)
    rev1 = _get_financial_val(stock, "financials", ["Total Revenue"], 1)
    ni = _get_financial_val(stock, "financials", ["Net Income"], 0)
    oi = _get_financial_val(stock, "financials", ["Operating Income", "EBIT"], 0)
    gp = _get_financial_val(stock, "financials", ["Gross Profit"], 0)
    ta = _get_financial_val(stock, "balance_sheet", ["Total Assets"], 0)
    te = _get_financial_val(stock, "balance_sheet", ["Stockholders Equity", "Total Equity"], 0)
    td = _get_financial_val(stock, "balance_sheet", ["Total Debt", "Long Term Debt"], 0)
    ca = _get_financial_val(stock, "balance_sheet", ["Current Assets"], 0)
    clb = _get_financial_val(stock, "balance_sheet", ["Current Liabilities"], 0)
    cash = _get_financial_val(stock, "balance_sheet", ["Cash And Cash Equivalents"], 0)

    rev_growth = (rev0 - rev1) / abs(rev1) if rev0 and rev1 and rev1 != 0 else None
    gross_margin = gp / rev0 if gp and rev0 and rev0 != 0 else None
    net_margin = ni / rev0 if ni and rev0 and rev0 != 0 else None
    roe = ni / te if ni and te and te > 0 else None  # FIX 1.3: guard negative equity
    de_ratio = td / te if td and te and te > 0 else None  # FIX 1.3
    current_ratio = ca / clb if ca and clb and clb != 0 else None
    fcf_margin = lfcf / rev0 if lfcf and rev0 and rev0 != 0 else None
    net_debt = (td or 0) - (cash or 0)

    gp1 = _get_financial_val(stock, "financials", ["Gross Profit"], 1)
    rev1v = _get_financial_val(stock, "financials", ["Total Revenue"], 1)
    gm_prev = gp1 / rev1v if gp1 and rev1v and rev1v != 0 else None

    # ════════════════════════════════════════════════
    # SECTION A: VERDICT
    # ════════════════════════════════════════════════
    row = 1
    ws.merge_cells("A1:G2")
    c = ws["A1"]
    c.value = f"INVESTMENT VERDICT: {info.get('shortName', 'N/A')} ({cfmt['code']})"
    c.font = Font(name="Arial", bold=True, color="1B2A4A", size=16)
    c.alignment = Alignment(horizontal="center", vertical="center")
    ws.row_dimensions[1].height = 25; ws.row_dimensions[2].height = 25

    row = 4
    ws.merge_cells("A4:B5")
    vc = ws["A4"]

    # FIX: Check if DCF data is available
    dcf_available = dcf["fcf_source"] != "no_data"

    if not dcf_available:
        vc.value = "N/A"
        vc.fill = PatternFill("solid", fgColor="808080")
        vc.font = Font(name="Arial", bold=True, color="FFFFFF", size=20)
        ws.cell(row=4, column=3, value="Insufficient data for DCF valuation").font = WARN_FONT
    else:
        # FIX 2.2: Stricter, symmetric thresholds using weighted MoS
        if weighted_mos > 0.30:
            vc.value = "STRONG BUY"; vc.fill = PatternFill("solid", fgColor="004D00")
            vc.font = Font(name="Arial", bold=True, color="FFFFFF", size=20)
        elif weighted_mos > 0.15:
            vc.value = "BUY"; vc.fill = PatternFill("solid", fgColor="006100")
            vc.font = Font(name="Arial", bold=True, color="FFFFFF", size=20)
        elif weighted_mos > -0.15:
            vc.value = "HOLD"; vc.fill = PatternFill("solid", fgColor="BF8F00")
            vc.font = Font(name="Arial", bold=True, color="FFFFFF", size=20)
        elif weighted_mos > -0.30:
            vc.value = "SELL"; vc.fill = PatternFill("solid", fgColor="C00000")
            vc.font = Font(name="Arial", bold=True, color="FFFFFF", size=20)
        else:
            vc.value = "STRONG SELL"; vc.fill = PatternFill("solid", fgColor="800000")
            vc.font = Font(name="Arial", bold=True, color="FFFFFF", size=20)

        ws.cell(row=4, column=3, value="Probability-weighted DCF verdict").font = NOTE_FONT

    vc.alignment = Alignment(horizontal="center", vertical="center")
    ws.row_dimensions[4].height = 22; ws.row_dimensions[5].height = 22

    # ── Confidence level ──
    fcf_hist = dcf["fcf_history"]
    n_years = len(fcf_hist)
    fcf_std = None
    if len(fcf_hist) >= 2:
        mean_fcf = np.mean(fcf_hist)
        if mean_fcf != 0:
            fcf_std = np.std(fcf_hist) / abs(mean_fcf)

    if n_years >= 4 and dcf["beta"] is not None and (fcf_std is None or fcf_std < 0.30):
        confidence = "High"
    elif n_years >= 2:
        confidence = "Medium"
    else:
        confidence = "Low"

    if dcf["fcf_source"] in ("estimated_ni", "no_data"):
        confidence = "Low"  # Force low confidence for estimated FCF

    # ── Risk level (FIX 2.2: sector-aware) ──
    beta_val = dcf["beta"]
    risk_score = 0
    if beta_val is not None and beta_val > 1.5:
        risk_score += 2
    elif beta_val is not None and beta_val > 1.2:
        risk_score += 1

    de_thresh = sbm.get("de_threshold")
    if de_ratio is not None and de_thresh is not None:
        if de_ratio > de_thresh * 1.5:
            risk_score += 2
        elif de_ratio > de_thresh:
            risk_score += 1

    if lfcf is not None and lfcf < 0:
        risk_score += 2

    if risk_score >= 3:
        risk = "High"
    elif risk_score >= 1:
        risk = "Medium"
    else:
        risk = "Low"

    # Investment horizon
    if weighted_mos > 0.30:
        horizon = "Long-term (3+ years)"
    elif weighted_mos > 0.10:
        horizon = "Medium-term (1-3 years)"
    else:
        horizon = "Short-term (< 1 year)"

    # ── Summary table ──
    row = 7
    summary_data = [
        ("Weighted Fair Value (3 scenarios)", weighted_iv, CUR),
        ("Base Case Intrinsic Value", intrinsic, CUR),
        ("Current Price", cp, CUR),
        ("Weighted Upside / Downside", weighted_mos, PCT),
        ("Base Case Margin of Safety", mos, PCT),
        ("Analyst Consensus", sg(info, "recommendationKey", "N/A"), None),
        ("Analyst Target (Mean)", sg(info, "targetMeanPrice"), CUR),
        ("Confidence Level", confidence, None),
        ("Investment Horizon", horizon, None),
