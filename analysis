def create_financials(wb, stock):
    ws = wb.create_sheet("Financial Statements"); ws.sheet_properties.tabColor = "2E5090"
    cr = 1
    for sn, data in {
        "INCOME STATEMENT": stock.financials,
        "BALANCE SHEET": stock.balance_sheet,
        "CASH FLOW STATEMENT": stock.cashflow,
    }.items():
        if data is None or data.empty:
            ws.cell(row=cr, column=1, value=f"{sn} - No data").font = S_FONT; cr += 3; continue
        data = data.iloc[:, :5]
        yrs = [c.strftime("%Y") if hasattr(c, "strftime") else str(c) for c in data.columns]
        ws.merge_cells(start_row=cr, start_column=1, end_row=cr, end_column=len(yrs) + 1 + max(len(yrs) - 1, 0))
        ws.cell(row=cr, column=1, value=sn).font = S_FONT; cr += 1
        hdrs = ["Item"] + yrs
        yoyh = [f"YoY {yrs[i-1]}/{yrs[i]}" for i in range(1, len(yrs))] if len(yrs) > 1 else []
        ah = hdrs + yoyh
        for j, h in enumerate(ah, 1):
            ws.cell(row=cr, column=j, value=h)
        sh(ws, cr, len(ah)); cr += 1; ds = cr

        for idx, nm in enumerate(data.index):
            cl = 1
            ws.cell(row=cr, column=cl, value=str(nm)).font = L_FONT
            ws.cell(row=cr, column=cl).border = BDR; cl += 1
            vals = []
            for yi in range(len(yrs)):
                v = data.iloc[idx, yi]
                if pd.notna(v):
                    c = ws.cell(row=cr, column=cl, value=float(v)); sd(c, NUM)
                    vals.append(float(v))
                else:
                    ws.cell(row=cr, column=cl, value="-"); vals.append(None)
                cl += 1
            for i in range(len(yrs) - 1):
                nw, ol = vals[i], vals[i + 1]
                yoy = sdv((nw - ol), abs(ol)) if nw is not None and ol is not None else None
                c = ws.cell(row=cr, column=cl, value=yoy); sd(c, PCT); cl += 1
            alt_row(ws, cr, cl - 1)
            cr += 1

        if yoyh:
            ys = len(yrs) + 2; ye = ys + len(yoyh) - 1
            acf(ws, f"{get_column_letter(ys)}{ds}:{get_column_letter(ye)}{cr - 1}")
        cr += 2

    ws.freeze_panes = "B3"; aw(ws, 14, 25); ws.column_dimensions["A"].width = 35


