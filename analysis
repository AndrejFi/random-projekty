    ticker = sys.argv[1].upper()
    print(f"\n{'='*60}")
    print(f"  Stock Analysis Tool v2.0 (Audit-Fixed) - {ticker}")
    print(f"{'='*60}\n")

    print(f"[1/8] Downloading data for {ticker}...")
    stock = yf.Ticker(ticker)
    try:
        info = stock.info
