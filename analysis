def _write_sensitivity_table(ws, row, base_dcf, stock, info):
    """Write WACC x Terminal Growth sensitivity matrix to sheet."""
    cfmt = get_currency_formats(info)
    CUR = cfmt["CUR"]

    ws.merge_cells(f"A{row}:G{row}")
    ws[f"A{row}"].value = "SENSITIVITY ANALYSIS (Intrinsic Value / Share)"
    ws[f"A{row}"].font = S_FONT; row += 2

    wacc_deltas = [-0.02, -0.01, 0, 0.01, 0.02]
    tg_deltas = [-0.010, -0.005, 0, 0.005, 0.010]

    # Corner label
    ws.cell(row=row, column=1, value="WACC ↓ \\ Tg →").font = L_FONT
    ws.cell(row=row, column=1).border = BDR

    # Column headers (terminal growth)
    for j, td in enumerate(tg_deltas):
        tg_val = base_dcf["terminal_g"] + td
        c = ws.cell(row=row, column=j + 2, value=tg_val); sd(c, PCT)
        c.font = H_FONT; c.fill = ACCENT
    row += 1

    cp = base_dcf["cp"]

    for wd in wacc_deltas:
        w_val = base_dcf["wacc"] + wd
        c = ws.cell(row=row, column=1, value=w_val); sd(c, PCT); c.font = L_FONT

        for j, td in enumerate(tg_deltas):
            tg_val = base_dcf["terminal_g"] + td
            if w_val <= tg_val:
                ws.cell(row=row, column=j + 2, value="N/A").font = D_FONT
                ws.cell(row=row, column=j + 2).border = BDR
                continue

            dcf = _compute_dcf(stock, info, wacc_override=w_val, tg_override=tg_val)
            iv = dcf["intrinsic"]
            c = ws.cell(row=row, column=j + 2, value=iv); sd(c, CUR)

            # Color coding by margin of safety
            if cp and cp > 0:
                mos = (iv - cp) / cp
                if mos > 0.20:
                    c.fill = GREEN_BG
                elif mos < -0.10:
                    c.fill = RED_BG
                else:
                    c.fill = YELLOW_BG

            # Highlight the base case cell
            if wd == 0 and td == 0:
                c.font = Font(name="Arial", bold=True, color="1B2A4A", size=11)
                c.border = Border(
                    left=Side(style="medium", color="1B2A4A"),
                    right=Side(style="medium", color="1B2A4A"),
                    top=Side(style="medium", color="1B2A4A"),
                    bottom=Side(style="medium", color="1B2A4A"),
                )

        row += 1

    # Legend
    row += 1
    ws.merge_cells(f"A{row}:G{row}")
    ws[f"A{row}"].value = "Green = >20% upside (BUY zone) | Yellow = ±20% (HOLD zone) | Red = >10% downside (SELL zone) | Bold = Base case"
    ws[f"A{row}"].font = NOTE_FONT
    return row + 2


