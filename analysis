def sh(ws, r, mc, f=ACCENT):
    for c in range(1, mc + 1):
        cl = ws.cell(row=r, column=c)
        cl.font = H_FONT; cl.fill = f
        cl.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
        cl.border = BDR

def sd(cell, fmt=None, inp=False):
    cell.font = B_INPUT if inp else D_FONT
    cell.fill = INPUT_BG if inp else PatternFill()
    cell.border = BDR
    cell.alignment = Alignment(horizontal="center", vertical="center")
    if fmt:
        cell.number_format = fmt

def aw(ws, mn=10, mx=30):
    for cc in ws.columns:
        l = mn; cl = get_column_letter(cc[0].column)
        for c in cc:
            if c.value:
                l = max(l, min(len(str(c.value)) + 3, mx))
        ws.column_dimensions[cl].width = l

def acf(ws, rng):
    ws.conditional_formatting.add(
        rng, CellIsRule(operator="greaterThan", formula=["0"],
                        fill=PatternFill("solid", fgColor="E2EFDA"), font=Font(color="006100")))
    ws.conditional_formatting.add(
        rng, CellIsRule(operator="lessThan", formula=["0"],
                        fill=PatternFill("solid", fgColor="FCE4EC"), font=Font(color="9C0006")))

def sg(info, k, d="N/A"):
    v = info.get(k, d)
    return v if v is not None else d

def sdv(a, b):
    """Safe division with None/NaN/zero handling."""
    try:
        if b is None or b == 0 or pd.isna(b):
            return None
        if a is None or pd.isna(a):
            return None
        return a / b
    except:
        return None

def alt_row(ws, row, max_col):
    """Apply alternating row shading."""
    if row % 2 == 0:
        for cc in range(1, max_col + 1):
            if ws.cell(row=row, column=cc).fill == PatternFill():
                ws.cell(row=row, column=cc).fill = LIGHT


