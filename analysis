    create_valuation(wb, stock, info)

    print("[7/8] Technical, Dividends & Risk...")
    create_technical(wb, ticker, hist, info)
    create_dividends(wb, stock, info)
    create_risk(wb, stock, info, hist)

    print("[8/8] Investment Verdict (Multi-Scenario)...")
    create_investment_verdict(wb, stock, info, hist)

    fn = f"{ticker}_Analysis_{datetime.date.today().strftime('%Y%m%d')}.xlsx"
