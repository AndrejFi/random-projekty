def create_ratios(wb, stock, info):
    ws = wb.create_sheet("Financial Ratios"); ws.sheet_properties.tabColor = "4472C4"
    inc = stock.financials; bs = stock.balance_sheet
    if inc is None or bs is None:
        ws.cell(row=1, column=1, value="Insufficient data").font = S_FONT; return

    yc = min(len(inc.columns), len(bs.columns), 5)
    yrs = [c.strftime("%Y") if hasattr(c, "strftime") else str(c) for c in inc.columns[:yc]]

    def gv(df, rn, ci):
        if df is None or df.empty:
            return None
        m = [r for r in df.index if rn.lower() in str(r).lower()]
        if m and ci < len(df.columns):
            v = df.loc[m[0]].iloc[ci]
            return float(v) if pd.notna(v) else None
        return None

    secs = {}
    neg_equity_years = []

    for i in range(yc):
        rv = gv(inc, "Total Revenue", i); ni = gv(inc, "Net Income", i)
        oi = gv(inc, "Operating Income", i) or gv(inc, "EBIT", i)
        gp = gv(inc, "Gross Profit", i); ebitda = gv(inc, "EBITDA", i)
        ie = gv(inc, "Interest Expense", i)
        ta = gv(bs, "Total Assets", i)
        te = gv(bs, "Stockholders Equity", i) or gv(bs, "Total Equity", i)
        td = gv(bs, "Total Debt", i) or gv(bs, "Long Term Debt", i)
        ca = gv(bs, "Current Assets", i)
        cl_val = gv(bs, "Current Liabilities", i)
        inv = gv(bs, "Inventory", i) or 0
        cogs = gv(inc, "Cost Of Revenue", i)

        # FIX 1.3: Guard negative equity
        if te is not None and te < 0:
            neg_equity_years.append(yrs[i])
            roe_val = None  # ROE meaningless with negative equity
            de_val = None   # D/E meaningless
            em_val = None   # Equity multiplier meaningless
        else:
            roe_val = sdv(ni, te)
            de_val = sdv(td, te)
            em_val = sdv(ta, te)

        secs.setdefault("PROFITABILITY", []).append({
            "ROE": roe_val, "ROA": sdv(ni, ta),
            "Net Margin": sdv(ni, rv), "Operating Margin": sdv(oi, rv),
            "Gross Margin": sdv(gp, rv), "EBITDA Margin": sdv(ebitda, rv),
        })
        secs.setdefault("LIQUIDITY", []).append({
            "Current Ratio": sdv(ca, cl_val),
            "Quick Ratio": sdv((ca - inv) if ca and inv is not None else None, cl_val),
        })
        secs.setdefault("LEVERAGE", []).append({
            "Debt-to-Equity": de_val,
            "Debt-to-Assets": sdv(td, ta),
