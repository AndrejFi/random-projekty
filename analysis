    for lb, v, fm in summary_data:
        ws.cell(row=row, column=1, value=lb).font = L_FONT
        ws.cell(row=row, column=1).border = BDR
        c = ws.cell(row=row, column=2, value=v)
        if fm:
            sd(c, fm)
        else:
            c.font = D_FONT; c.border = BDR; c.alignment = Alignment(horizontal="center")
        alt_row(ws, row, 2)
        row += 1

    # Color upside/downside
    acf(ws, f"B10:B11")

    # ════════════════════════════════════════════════
    # SECTION B: MULTI-SCENARIO DCF
    # ════════════════════════════════════════════════
    row += 1
    ws.merge_cells(f"A{row}:G{row}")
    ws[f"A{row}"].value = "MULTI-SCENARIO DCF"; ws[f"A{row}"].font = S_FONT; row += 2

    scen_hdrs = ["Scenario", "Probability", "FCF Growth (Y1-5)", "WACC", "Term. Growth", "Intrinsic Value", "Margin of Safety"]
    for j, h in enumerate(scen_hdrs, 1):
        ws.cell(row=row, column=j, value=h)
    sh(ws, row, len(scen_hdrs)); row += 1

    for name in ["Bull", "Base", "Bear"]:
        sc = scenarios[name]
        ws.cell(row=row, column=1, value=name).font = L_FONT; ws.cell(row=row, column=1).border = BDR
        for j, (v, fm) in enumerate([
            (sc["prob"], PCT), (sc["g1"], PCT), (sc["wacc"], PCT),
            (sc["tg"], PCT), (sc["intrinsic"], CUR), (sc["mos"], PCT),
        ], 2):
            c = ws.cell(row=row, column=j, value=v); sd(c, fm)

        # Color the row by scenario
        if name == "Bull":
            for cc in range(1, 8):
                ws.cell(row=row, column=cc).fill = GREEN_BG
        elif name == "Bear":
            for cc in range(1, 8):
                ws.cell(row=row, column=cc).fill = RED_BG
        row += 1

    # Weighted row
    ws.cell(row=row, column=1, value="WEIGHTED FAIR VALUE").font = Font(name="Arial", bold=True, color="1B2A4A", size=11)
    ws.cell(row=row, column=1).border = BDR
    c = ws.cell(row=row, column=6, value=weighted_iv); sd(c, CUR)
    c.font = Font(name="Arial", bold=True, color="1B2A4A", size=12)
    if cp and cp > 0:
        c2 = ws.cell(row=row, column=7, value=weighted_mos); sd(c2, PCT)
        c2.font = Font(name="Arial", bold=True, size=12)
    row += 2

    # ════════════════════════════════════════════════
